# Copy to .env.local and fill in values. Never commit .env.local.
# See docs/handoff/SECRETS.md for where each value lives (Vercel, Supabase, etc.).

# --- App URL (recommended for production auth redirects) ---
# Public site origin used for Supabase password-reset and other auth redirectTo URLs.
# Set on Vercel to your canonical production domain, e.g. https://follow-the-crowd.vercel.app
NEXT_PUBLIC_APP_URL=https://follow-the-crowd.vercel.app

# --- Supabase (required) ---
# Public keys are exposed to the browser; security relies on RLS, not hiding the anon key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only (required for event-plan API) ---
OPENAI_API_KEY=

# --- Google Maps (optional; venue map in UI) ---
# Restrict by HTTP referrer in Google Cloud Console for production domains.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Local scripts only (optional; not used by Next.js runtime) ---
# GOOGLE_PLACES_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # bypasses RLS — local diagnostics only; do not add to Vercel unless required
